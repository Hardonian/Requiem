# Requiem repository local environment example
#
# Copy to `.env` or `.env.local` only for local development.
# Do not treat these values as a production deployment template.
# ReadyLayer deployment-specific variables are documented in `ready-layer/.env.example`
# and `docs/ENVIRONMENT.md`.

# -----------------------------------------------------------------------------
# Database / Prisma (needed for local DB-backed ReadyLayer workflows)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://requiem_user:requiem_password@localhost:5432/requiem_db"
DIRECT_DATABASE_URL="postgresql://requiem_user:requiem_password@localhost:5432/requiem_db"

# -----------------------------------------------------------------------------
# ReadyLayer auth + API wiring
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://example.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="replace-with-dev-anon-key"
SUPABASE_SERVICE_ROLE_KEY=""
REQUIEM_AUTH_SECRET="replace-with-local-dev-secret"
REQUIEM_API_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Local auth mode controls
# -----------------------------------------------------------------------------
# In production/staging/test, auth is strict by default.
# In development, insecure bearer-token fallback requires BOTH:
#   REQUIEM_AUTH_MODE=local-dev
#   REQUIEM_ALLOW_INSECURE_DEV_AUTH=1
# Never enable this in a deployed environment.
REQUIEM_AUTH_MODE="local-dev"
REQUIEM_ALLOW_INSECURE_DEV_AUTH="0"

# -----------------------------------------------------------------------------
# Optional build/runtime metadata
# -----------------------------------------------------------------------------
VERCEL_GIT_COMMIT_SHA=""
BUILD_TIME=""
REQUIEM_PROMPT_VERSION=""
REQUIEM_CORE_VERSION=""
