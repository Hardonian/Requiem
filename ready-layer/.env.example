# ReadyLayer deployment environment contract
#
# This file is the operator-facing contract for the Next.js app in `ready-layer/`.
# Safe examples only. Replace values before real use.

# -----------------------------------------------------------------------------
# Required for authenticated ReadyLayer UI flows
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://example.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-public-anon-key

# -----------------------------------------------------------------------------
# Required for strict authenticated API mode outside local-dev fallback
# -----------------------------------------------------------------------------
REQUIEM_AUTH_SECRET=replace-with-long-random-secret

# -----------------------------------------------------------------------------
# Required only if you want routes that call an external Requiem API/runtime
# -----------------------------------------------------------------------------
REQUIEM_API_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Needed for Prisma/database workflows and CI environments that run Prisma
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://requiem_user:requiem_password@localhost:5432/requiem_db
DIRECT_DATABASE_URL=postgresql://requiem_user:requiem_password@localhost:5432/requiem_db

# -----------------------------------------------------------------------------
# Optional server-side integrations
# -----------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Local-development-only auth relaxation
# Never enable on a real deployment.
# -----------------------------------------------------------------------------
REQUIEM_AUTH_MODE=local-dev
REQUIEM_ALLOW_INSECURE_DEV_AUTH=0

# -----------------------------------------------------------------------------
# Optional build/runtime metadata shown in status surfaces
# -----------------------------------------------------------------------------
VERCEL_GIT_COMMIT_SHA=
BUILD_TIME=
REQUIEM_PROMPT_VERSION=
REQUIEM_CORE_VERSION=
