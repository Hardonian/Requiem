{
  "name": "ready-layer",
  "version": "1.0.0",
  "private": true,
  "description": "ReadyLayer \u2014 AI control plane dashboard for the Requiem engine",
  "scripts": {
    "dev": "next dev",
    "build": "pnpm run lint && pnpm run type-check && next build",
    "analyze": "ANALYZE=true pnpm run build",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "postinstall": "echo 'Run prisma:generate manually after install'",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:validate": "prisma validate",
    "test": "vitest run",
    "test:api": "vitest run tests/api-contract.test.ts tests/no-hard-500.test.ts",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "verify": "pnpm run type-check && pnpm run lint",
    "doctor": "echo 'Run doctor from root: pnpm doctor'",
    "verify:boundaries": "node ../scripts/run-tsx.mjs scripts/verify-boundaries.ts",
    "verify:integrity": "node ../scripts/run-tsx.mjs scripts/verify-integrity.ts",
    "verify:policy": "node ../scripts/run-tsx.mjs scripts/verify-policy.ts",
    "verify:replay": "node ../scripts/run-tsx.mjs scripts/verify-replay.ts",
    "verify:web": "node ../scripts/run-tsx.mjs scripts/verify-web.ts",
    "verify:all": "pnpm run verify:web && pnpm run verify:boundaries && pnpm run verify:integrity && pnpm run verify:policy && pnpm run verify:replay",
    "smoke:api": "bash scripts/smoke-api.sh",
    "test:mcp-routes": "vitest run tests/mcp-route*.test.ts",
    "verify:route-map": "node ../scripts/run-tsx.mjs scripts/route-map-check.ts",
    "generate:auth-truth": "node ../scripts/run-tsx.mjs scripts/generate-auth-truth-matrices.ts",
    "verify:survivability": "node ../scripts/run-tsx.mjs scripts/verify-survivability.ts",
    "verify:routes-runtime": "node ../scripts/run-tsx.mjs scripts/verify-routes-runtime.ts"
  },
  "dependencies": {
    "@babel/parser": "^7.29.2",
    "@babel/types": "^7.28.6",
    "@octokit/app": "^16.1.2",
    "@octokit/rest": "^22.0.1",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@requiem/ai": "workspace:*",
    "@supabase/postgrest-js": "^1.15.0",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.1",
    "@tanstack/react-query": "^5.96.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "commander": "^14.0.2",
    "framer-motion": "^12.26.2",
    "js-yaml": "^4.1.0",
    "lucide-react": "^0.577.0",
    "next": "^16.2.3",
    "next-themes": "^0.4.6",
    "pino": "^10.2.0",
    "pino-pretty": "^13.1.3",
    "rate-limiter-flexible": "^9.0.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "recharts": "^3.6.0",
    "redis": "^5.10.0",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@next/eslint-plugin-next": "^16.2.2",
    "@playwright/test": "^1.59.1",
    "@prisma/client": "^5.22.0",
    "@prisma/config": "^7.6.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.39",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.2.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^17.0.0",
    "playwright": "^1.59.1",
    "postcss": "^8.5.8",
    "prisma": "^5.22.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20.11.0"
  }
}
